# ===== 声图 SoundMap 配置 =====
# 媒体签名密钥（可选）：签发 ASR 拉取/导出下载的临时链接。
# 单机可不配（自动生成并持久化到 data/.media-secret）；多实例部署必须配同一个值。
# MEDIA_SIGNING_SECRET=
# 复制为 .env 后填写。任何一项缺失都会自动降级为 mock 模式（假数据跑通全流程）。

# 服务端口
PORT=3000

# ---- 账号与微信登录 ----
# 正式环境设为 1；未开启时使用本地 local 身份，兼容 Phase 0 数据。
AUTH_REQUIRED=0
# 仅 localhost/局域网开发使用（公网/cpolar 请求会被拒绝）。正式环境仍必须为 0。
AUTH_DEV_LOGIN=1
# 微信开放平台「移动应用」审核通过后获得；AppSecret 只能放服务端 .env，禁止写入 Flutter。
WECHAT_APP_ID=
WECHAT_APP_SECRET=
# iOS 微信 SDK 必填，例如 https://example.com/wechat/ （Android 可留空）
WECHAT_UNIVERSAL_LINK=
# 至少 32 位随机字符串，用于给 ASR 临时音频地址签名。
MEDIA_SIGNING_SECRET=change-this-to-a-long-random-secret

# ---- ASR 转写 ----
# 可选: dashscope | mock
ASR_PROVIDER=mock
# 阿里百炼 API Key（https://bailian.console.aliyun.com/ 开通，转写与 LLM 共用一个 Key）
DASHSCOPE_API_KEY=
# 业务空间专属 Key（sk-ws- 开头）需要配套专属 API Host（控制台 Key 页面显示的那个），
# 官方主账号 Key 留空即可（默认 https://dashscope.aliyuncs.com）
DASHSCOPE_BASE_URL=
# paraformer 文件转写要求音频 URL 可公网访问。
# 本地开发用 ngrok / cpolar 等内网穿透，把公网地址填在这里（如 https://xxx.ngrok.io）
PUBLIC_BASE_URL=
# 转写模型
ASR_MODEL=fun-asr
# 热词表 ID（可选，强烈推荐）：在百炼控制台创建热词表，填人名、称呼、专有名词
#（目标模型选择与 ASR_MODEL 一致），把生成的 ID 填这里，专治人名识别错
ASR_VOCABULARY_ID=

# ---- 讯飞语音转写（可选，ASR_PROVIDER=xfyun 时启用）----
# 控制台 https://console.xfyun.cn "语音转写"服务页的凭证；直传文件，无需 PUBLIC_BASE_URL
XFYUN_APPID=
XFYUN_SECRET_KEY=

# ---- 火山引擎·豆包录音文件识别 2.0（可选，ASR_PROVIDER=volcengine 时启用）----
# https://console.volcengine.com/speech/new/ 开通"录音文件识别2.0"后创建 API Key
# 需要 PUBLIC_BASE_URL（音频通过 URL 提交）
VOLC_API_KEY=

# ---- LLM 总结/思维导图 ----
# 可选: dashscope | mock
LLM_PROVIDER=mock
# 通过百炼 OpenAI 兼容接口调用，qwen-plus 性价比高，也可填 deepseek-v3 等
LLM_MODEL=qwen-plus

# ---- 上传与 API 保护 ----
# 普通/分片上传会校验文件内容签名，拒绝仅修改扩展名的非音频文件。
# API 按客户端 IP 限流；多实例部署应在网关或 Redis 层配置共享限流。
# API_RATE_LIMIT_MAX=120
# API_RATE_LIMIT_WINDOW_MS=60000
# 认证接口使用更严格的独立限流（默认每分钟 20 次）。
# AUTH_RATE_LIMIT_MAX=20
# AUTH_RATE_LIMIT_WINDOW_MS=60000

# ---- 任务可靠性 ----
# 单个处理任务总时限（默认 30 分钟）；BullMQ 停滞任务参数见 server/queue/redis.js。
# QUEUE_TASK_TIMEOUT_MS=1800000
# QUEUE_LOCK_DURATION_MS=2100000
# QUEUE_STALLED_INTERVAL_MS=30000
# QUEUE_MAX_STALLED_COUNT=1

# ===== 生产环境基础设施（Phase 1）=====
# 以下配置全部可选：不填则自动降级为开发模式（JSON 文件存储 + 内存队列 + 本地磁盘）。

# ---- PostgreSQL 数据库 ----
# JSON 开发模式默认保留最近 3 份 db.json 备份（db.json.bak.1...），可设为 0 禁用。
# SOUNDMAP_JSON_BACKUP_COUNT=3
# 填写后自动从 JSON 文件存储切换到 PostgreSQL（需先执行 migrations.sql）
# DATABASE_URL=postgresql://user:password@localhost:5432/soundmap
# 连接池大小（默认 10）
# PG_POOL_MAX=10

# ---- Redis 队列（BullMQ）----
# 填写后自动从内存队列切换到 Redis 队列，需配合 worker.js 独立进程消费
# REDIS_URL=redis://localhost:6379
# 或分开配置
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# Worker 并发数（默认 2）
# QUEUE_CONCURRENCY=2

# ---- 对象存储（S3 兼容：AWS S3 / MinIO / 阿里云 OSS / 腾讯云 COS）----
# 填写后自动从本地磁盘切换到 S3 兼容对象存储
# S3_BUCKET=soundmap-uploads
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=          # MinIO 或自建: https://minio.example.com；AWS S3 留空
# S3_FORCE_PATH_STYLE=0 # MinIO 设为 1，AWS S3 设为 0
